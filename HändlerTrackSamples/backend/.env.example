# ============================================================
# HÄNDLER TRACKSAMPLES - CONFIGURACIÓN DE ENTORNO
# ============================================================
# Copie este archivo a .env y complete los valores
# NO incluya este archivo en el control de versiones
# ============================================================

# ============================================================
# SEGURIDAD - REQUERIDOS
# ============================================================

# Clave secreta para JWT (GENERE UNA CLAVE ÚNICA)
# Ejemplo: generate using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ============================================================
# BASE DE DATOS - REQUERIDOS
# ============================================================

# URL de conexión a MySQL
# Formato: mysql+pymysql://usuario:contraseña@host:puerto/base_datos
DATABASE_URL=mysql+pymysql://handler_user:your_password_here@localhost:3306/handler_tracksamples

# ============================================================
# CONFIGURACIÓN DE APLICACIÓN
# ============================================================

# Origins permitidos para CORS (separados por coma)
# NO use * en producción
CORS_ORIGINS=http://localhost:3000

# Tiempo de expiración del token JWT en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Directorio base para certificados CoA
COA_BASE_DIR=C:\\Handler\\Certificados
